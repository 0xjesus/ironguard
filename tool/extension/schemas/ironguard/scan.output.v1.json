{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "ScanResult",
  "additionalProperties": true,
  "properties": {
    "ok": { "type": "boolean" },
    "repo": { "type": "string" },
    "risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "summary": {
      "type": "object",
      "properties": {
        "files_scanned": { "type": "integer" },
        "secrets_found": { "type": "integer" },
        "dependencies_checked": { "type": "integer" },
        "vulnerable_dependencies": { "type": "integer" },
        "malicious_dependencies": { "type": "integer" }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "line": { "type": "integer" },
          "kind": { "type": "string" },
          "severity": { "type": "string" },
          "preview": { "type": "string" }
        }
      }
    },
    "vulnerabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ecosystem": { "type": "string" },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "advisory_ids": { "type": "array", "items": { "type": "string" } },
          "advisory_count": { "type": "integer" },
          "malicious": { "type": "boolean" }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
